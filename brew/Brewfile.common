# Universally welcome on any Mac (personal or work).
# Corp laptops typically provide editor + terminal via Self Service / MDM, so
# iterm2 / sublime-text / visual-studio-code live in Brewfile.personal instead.
# If a corp machine genuinely lacks one, add it to Brewfile.work.

brew "tmux"
brew "duti"
brew "emacs"
brew "exiftool"
brew "gh"
brew "git"
brew "poppler"

cask "claude-code"
cask "elgato-control-center"
