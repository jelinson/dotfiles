# aliases
alias l='ls -A'
alias ls='ls -A'
alias 'cd..'='cd ..'
alias grep='grep --color=auto'

# useful
alias ssh-copy-key='cat ~/.ssh/id_rsa.pub | pbcopy'

alias j='jobs'
alias cl='clear'

# emacs no window
alias emacs='emacs -nw'
# misspellings
alias emac='emacs'
alias em='emacs'
alias emasc='emacs'
alias eamcs='emacs'
alias emcas='emacs'

# git shortcuts
alias gb='git branch'
alias gd='git diff'
alias gitcom='git commit -am'
alias gs='git status'
alias gl='git log'
alias gnew='git checkout -b'
alias gs='git status'
alias gm='git checkout master'
alias gsh='git show'
alias ghash='git rev-parse --short'
alias gp='git checkout -'
alias gmend='git commit --amend -m'
alias gsub='git submodule update'
alias gdom='git diff origin/master master'
alias gcp='git cherry-pick'

alias ext='exit'
alias exti='exit'
